balancer:
  enabled: false
worker:
  stopwords:
    enabled: true
  image:
    tag: 0.0.0-unstable
––– block: ./init/install –––
––– input –––
if timeout 300 bash -c 'while [[ ! $(kubectl get po 2>&1 | grep "Running" | wc -l) -eq 3 ]]; do sleep 1; done'; then echo "OK"; else echo "Failed waiting until pods was deployed"; kubectl get po -o wide || true; for pod in $(kubectl get po --no-headers 2>/dev/null | awk '$3 != "Running" {print $1}'); do kubectl describe pod "$pod" || true; done; false; fi
––– output –––
OK
––– input –––
kubectl get po | grep worker | cut -d " " -f1
