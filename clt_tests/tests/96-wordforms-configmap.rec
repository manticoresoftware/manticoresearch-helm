––– input –––
kubectl exec my-helm-manticoresearch-worker-0 -- mysql -h0 -P9306 -e "CREATE TABLE wf_products(title text) wordforms='/usr/share/manticore/wordforms/products/products.txt'; INSERT INTO wf_products(title) VALUES ('walk shoes');"; count=$(kubectl exec my-helm-manticoresearch-worker-0 -- mysql -h0 -P9306 -e "SELECT COUNT(*) FROM wf_products WHERE MATCH('walks')" | tr -dc "0-9"); echo "wordforms_match_count=$count"; test "$count" = "1"
