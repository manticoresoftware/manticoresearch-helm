release=my-helm status=deployed wordforms_configmap=product-wordforms
––– input –––
if timeout 420 bash -c 'until kubectl get pod my-helm-manticoresearch-worker-0 2>/dev/null | grep -q "1/1[[:space:]]*Running"; do sleep 2; done'; then kubectl get pod my-helm-manticoresearch-worker-0; else echo "worker_0_wait_failed"; kubectl get pod my-helm-manticoresearch-worker-0 2>/dev/null || true; kubectl describe pod my-helm-manticoresearch-worker-0 2>/dev/null || true; false; fi
