––– input –––
helm install my-helm --set balancer.enabled=false --set worker.replicaCount=1 --set worker.wordforms.enabled=true --set worker.wordforms.configMaps[0].name=product-wordforms --set worker.wordforms.configMaps[0].items[0].key=products.txt --set worker.wordforms.configMaps[0].items[0].path=products/products.txt ./charts/manticoresearch >/tmp/helm-install-wordforms.log 2>&1 && echo "release=my-helm status=deployed wordforms_configmap=product-wordforms"
