wordforms_match_count=1
––– input –––
helm uninstall my-helm; kubectl delete pvc -l app.kubernetes.io/component=worker >/dev/null 2>&1; kubectl delete configmap product-wordforms >/dev/null 2>&1; echo "wordforms cleanup deleted"
